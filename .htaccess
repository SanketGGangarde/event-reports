# Disable directory browsing
Options -Indexes -MultiViews

# Hide server signature
ServerSignature Off

# Enable URL rewriting
RewriteEngine On
RewriteBase /event-reports/

# Block access to sensitive files
<FilesMatch "(^\.|composer\.(json|lock)|\.env|\.git)">
    Require all denied
</FilesMatch>

# Protect configuration files
<FilesMatch "\.(ini|log|sh|sql|bak|env)">
    Require all denied
</FilesMatch>

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route all other requests to index.php
RewriteRule ^ index.php [L,QSA]

# -------------------------------
# SECURITY HEADERS
# -------------------------------

# Prevent clickjacking
Header always set X-Frame-Options "SAMEORIGIN"

# Prevent MIME sniffing
Header always set X-Content-Type-Options "nosniff"

# Enable XSS protection (legacy but still helpful)
Header always set X-XSS-Protection "1; mode=block"

# Strict transport security (HTTPS only)
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

# Referrer policy
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Content Security Policy (basic)
Header always set Content-Security-Policy "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval'"

# Remove powered-by header
Header unset X-Powered-By